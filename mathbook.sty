%% -*- mode: TeX -*-
%% -*- coding: utf-8 -*-
% mathbook.sty -- Preamble bundle for elegantbook math books
% (Chinese index, theorems+cleveref, biblatex tweaks)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mathbook}[2026/06/12 Math book preamble bundle]

\RequirePackage{bookmark}
\RequirePackage{xparse}

% Optional proof title (elegantbook proof + optional heading)
\makeatletter
\let\MBproof\proof
\let\endMBproof\endproof
\makeatother

\RenewDocumentEnvironment{proof}{ o }{%
  \begingroup
  \IfNoValueF{#1}{\renewcommand{\proofname}{#1}}%
  \MBproof
}{%
  \endMBproof
  \IfNoValueF{#1}{\renewcommand{\proofname}{证明}}%
  \endgroup
}

\ctexset{punct=banjiao}
\RequirePackage[all]{xy}
\RequirePackage{subcaption}
\RequirePackage{amsmath,amssymb,mathrsfs,mathtools,bbm}
\RequirePackage{enumitem}
\RequirePackage[nameinlink,capitalize]{cleveref}

\elegantnewtheorem{thm}{定理}{thmstyle}{thm}[theorem]
\elegantnewtheorem{lem}{引理}{thmstyle}{lem}[theorem]
\elegantnewtheorem{defn}{定义}{defstyle}{defn}[theorem]
\elegantnewtheorem{cor}{推论}{thmstyle}{cor}[theorem]
\elegantnewtheorem{prop}{命题}{prostyle}{prop}[theorem]
\elegantnewtheorem{examp}{例}{prostyle}{examp}[theorem]
\renewcommand{\examplename}{例}
\elegantnewtheorem{prob}{问题}{prostyle}{prob}[theorem]
\elegantnewtheorem{rmk}{注意}{attstyle}{rmk}[theorem]
\newtheorem{conj}{猜想}

\crefname{figure}{图}{图}
\Crefname{figure}{图}{图}
\crefname{equation}{式}{式}
\Crefname{equation}{式}{式}
\crefformat{equation}{式~(#2#1#3)}
\crefrangeformat{equation}{式~(#3#1#4)--(#5#2#6)}
\crefname{section}{节}{节}
\Crefname{section}{节}{节}
\crefformat{section}{第#2#1#3节}
\crefrangeformat{section}{第#3#1#4--#5#2#6节}
\crefname{chapter}{章}{章}
\Crefname{chapter}{章}{章}
\crefformat{chapter}{第#2#1#3章}
\crefrangeformat{chapter}{第#3#1#4--#5#2#6章}
\crefname{appchapter}{附录}{附录}
\Crefname{appchapter}{附录}{附录}
\crefformat{appchapter}{附录#2#1#3}
\crefrangeformat{appchapter}{附录#3#1#4--#5#2#6}
\crefname{thm}{定理}{定理}
\Crefname{thm}{定理}{定理}
\crefname{lem}{引理}{引理}
\Crefname{lem}{引理}{引理}
\crefname{defn}{定义}{定义}
\Crefname{defn}{定义}{定义}
\crefname{cor}{推论}{推论}
\Crefname{cor}{推论}{推论}
\crefname{prop}{命题}{命题}
\Crefname{prop}{命题}{命题}
\crefname{examp}{例}{例}
\Crefname{examp}{例}{例}
\crefname{prob}{问题}{问题}
\Crefname{prob}{问题}{问题}
\crefname{rmk}{注意}{注意}
\Crefname{rmk}{注意}{注意}

\pretocmd{\appendix}{%
  \crefalias{chapter}{appchapter}%
}{}{}
\numberwithin{equation}{section}
\numberwithin{figure}{section}

\RequirePackage[normalem]{ulem}
\newcommand{\iemph}[2][]{\uwave{#2}\if\relax\detokenize{#1}\relax\index{#2|hyperpage}\else\index{#1!#2|hyperpage}\fi}

\renewcommand{\thefootnote}{\fnsymbol{footnote}}
\makeatletter
\@newctr{footnote}[page]
\makeatother
\renewcommand{\Re}{\operatorname{Re}}
\renewcommand{\Im}{\operatorname{Im}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\End}{\mathrm{End}}

\setlength{\footskip}{14pt}

% Code listings (minted v3+; needs -shell-escape and latexminted on PATH)
\RequirePackage{minted}
\setminted{
  breaklines,
  breakanywhere,
  fontsize=\small,
  autogobble,
  tabsize=2
}
% Wolfram: stock Pygments mathematica lexer does not style builtins (Integrate, Sin).
% Custom lexer pygments/wolfram_lexer.py; run `make minted-setup` once.
\newcommand{\MBWolframLexer}{pygments/wolfram_lexer.py:WolframBookLexer}
\begingroup
\catcode`\^^M=\active
\gdef\MBWolframMinted@i#1{%
  \begin{minted}[#1]{\MBWolframLexer}^^M}%
\endgroup
\newenvironment{wolfram}%
  {\VerbatimEnvironment%
   \FVExtraReadOArgBeforeVEnv{\MBWolframMinted@i}}%
  {\end{minted}}
\newcommand{\wl}[1]{\mintinline{\MBWolframLexer}|#1|}

\RequirePackage{imakeidx}
\makeatletter
\def\imki@progdefault{zhmakeindex}
\makeatother
\makeindex[intoc, columns=2, columnseprule=false, columnsep=5pt, options={-s zh.ist -z pinyin}]

\ExecuteBibliographyOptions{
  doi=false,
  url=false,
  isbn=false,
  eprint=false
}
\DeclareFieldFormat{addendum}{%
  \addspace\href{https://mathscinet.ams.org/mathscinet-getitem?mr=#1}{MR#1}%
}

\endinput
