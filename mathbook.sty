\RequirePackage[checksum,lineno,labelnames,latex]{mpostinl}
\mpostsetup{template=images/\mpostfilename-#1.mps}

\begin{mpostdef}
  numeric u;
  u:=10pt;
  def draw_axis(expr O, len, s, labo, labx, laby) =
    drawarrow (s*len*left -- (1-s)*len*right) shifted O;
    drawarrow (s*len*down -- (1-s)*len*up) shifted O;
    label.lrt(labo, O);
    label.urt(laby, O + (1-s)*len*up);
    label.top(labx, O + (1-s)*len*right);
  enddef;
  vardef sawtooth_pen(expr teeth, width, height) =
    save p, i, step, half_step;
    path p;
    numeric step, half_step;
    step := width / teeth;
    half_step := step / 2;
    p := (0,0)
         for i=0 upto teeth-1:
           -- ((i*step + half_step), height)
           -- ((i+1)*step, 0)
         endfor
         -- (0,0) -- cycle;
    makepen(p shifted (-width/2, -height/2))
  enddef;
  def sawtooth_pen_default=sawtooth_pen_default(8,2bp,1bp) enddef;
  def arrow_label(expr p, dr, len)(text lab) =
    drawarrow ((-unitvector(dr))*len--origin) shifted p;
    label(lab, p-unitvector(dr)*(len+0.4u));
  enddef;
\end{mpostdef}

